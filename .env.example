PORT=4177
APP_URL=http://127.0.0.1:4177
UPLOAD_MAX_BYTES=10485760

# Image provider. API key is required for live generation.
# IMAGE_PROVIDER_MODE=openai-compatible or async-wrapper
IMAGE_PROVIDER_MODE=openai-compatible
OPENAI_IMAGE_BASE_URL=https://apic.aksearch.site/v1
IMAGE_ASYNC_BASE_URL=https://apic.aksearch.site/image/async-api
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_MODERATION=auto
IMAGE_JOB_TIMEOUT_MS=600000
IMAGE_JOB_POLL_MS=2000
IMAGE_JOB_MIN_POLL_MS=1000
IMAGE_REQUEST_TIMEOUT_MS=30000

# Optional OpenAI-compatible chat provider for prompt polishing.
# If OPENAI_CHAT_API_KEY is empty, the server reuses OPENAI_IMAGE_API_KEY.
OPENAI_CHAT_BASE_URL=https://apic.aksearch.site/v1
OPENAI_CHAT_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_CHAT_TIMEOUT_MS=30000
