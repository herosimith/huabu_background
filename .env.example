PORT=4177
HOST=127.0.0.1
APP_URL=http://127.0.0.1:4177
UPLOAD_MAX_BYTES=10485760
DATA_DIR=
STORAGE_DIR=

# Authentication. Use a random value of at least 32 bytes in production.
AUTH_SECRET=
AUTH_SESSION_HOURS=24
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NICKNAME=系统管理员
# Used only to seed the first versioned credit rule. Later changes are published in the admin console.
GENERATION_CREDIT_COST=1

# Image provider. API key is required for live generation.
# IMAGE_PROVIDER_MODE=openai-compatible or async-wrapper
IMAGE_PROVIDER_MODE=openai-compatible
OPENAI_IMAGE_BASE_URL=https://apic.aksearch.site/v1
IMAGE_ASYNC_BASE_URL=https://apic.aksearch.site/image/async-api
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
# Server-side fallback for API clients that omit size. The web app sends its selected preset explicitly.
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_MODERATION=auto
IMAGE_JOB_TIMEOUT_MS=600000
IMAGE_JOB_POLL_MS=2000
IMAGE_JOB_MIN_POLL_MS=1000
IMAGE_REQUEST_TIMEOUT_MS=30000

# Optional OpenAI-compatible chat provider for prompt polishing.
# If OPENAI_CHAT_API_KEY is empty, the server reuses OPENAI_IMAGE_API_KEY.
OPENAI_CHAT_BASE_URL=https://apic.aksearch.site/v1
OPENAI_CHAT_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_CHAT_TIMEOUT_MS=30000

# Optional local-only PaddleOCR sidecar for generated-text validation.
# It must bind to loopback. If it is unavailable, an image is not marked as text-verified.
OCR_SERVICE_URL=http://127.0.0.1:4188
OCR_REQUEST_TIMEOUT_MS=25000
OCR_MAX_INPUT_EDGE=2048
OCR_MIN_CONFIDENCE=0.7

# The rendering host must have this font family (or an equivalent CJK font).
TEXT_RENDER_FONT_FAMILY=Hiragino Sans GB, Noto Sans CJK SC, Microsoft YaHei, sans-serif
TEXT_RENDER_MAX_INPUT_PIXELS=40000000
