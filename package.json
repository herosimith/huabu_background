{
  "name": "adcraft-ai-mvp",
  "version": "1.0.0",
  "description": "AdCraft AI MVP backend for image2 storefront generation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "dev:ocr": "uv run --with-requirements ocr-sidecar/requirements.txt uvicorn --app-dir ocr-sidecar app:app --host 127.0.0.1 --port 4188",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "test:integration": "tsx scripts/integration-smoke.ts",
    "test:users": "tsx scripts/user-management-smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "multer": "^2.2.0",
    "nanoid": "^5.1.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
